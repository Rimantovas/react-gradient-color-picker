{
  "$schema": "https://biomejs.dev/schemas/2.4.5/schema.json",
  "files": {
    "includes": [
      "**",
      "!**/.tsimp",
      "!**/.yarn",
      "!**/coverage",
      "!**/dist",
      "!**/.pnp.cjs",
      "!**/.pnp.loader.mjs"
    ]
  },
  "formatter": {
    "lineWidth": 100,
    "indentStyle": "space"
  },
  "linter": {
    "rules": {
      "recommended": false,
      "complexity": {
        "noUselessSwitchCase": "off"
      }
    }
  },
  "css": {
    "formatter": {
      "enabled": true,
      "indentStyle": "space",
      "indentWidth": 2,
      "lineWidth": 100,
      "quoteStyle": "single"
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single"
    }
  },
  "overrides": [
    {
      "includes": ["**/package.json"],
      "formatter": {
        "lineWidth": 1
      }
    },
    {
      "includes": ["**/vite.config.ts"],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": { "level": "off", "options": { "allow": ["log"] } }
          }
        }
      }
    }
  ]
}
